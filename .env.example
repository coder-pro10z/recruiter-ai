# DATABASE
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jobfinder
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# TELEGRAM
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# APOLLO
APOLLO_API_KEY=your-apollo-key

# HUNTER
HUNTER_API_KEY=your-hunter-key

# GMAIL
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_FROM_ADDRESS=your@email.com

# NOTION
NOTION_API_KEY=your-notion-key
NOTION_DATABASE_ID=your-database-id

# ANTHROPIC (optional — for outreach generation)
ANTHROPIC_API_KEY=your-anthropic-key

# APPLICATION
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# SCHEDULER INTERVALS (seconds)
JOB_DETECTION_INTERVAL=300
FOLLOWUP_CHECK_INTERVAL=3600
MAILTRACK_CHECK_INTERVAL=1800
